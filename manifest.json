{
  "id": "potluck",
  "contexts": ["household", "shared_space"],
  "name": "Potluck",
  "version": "1.0.0",
  "description": "Create gatherings with dish slots and let members claim, swap, and release dishes without overbooking a category.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": ["food", "events", "potluck", "slot-claims"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_plaintext_columns": ["capacity", "note", "archived", "guest_name", "dish"],
  "shareable": {
    "event": {
      "table": "events",
      "title_column": "title",
      "columns": [
        { "column": "date", "label": "When", "format": "date" },
        { "column": "location", "label": "Where" },
        { "column": "notes", "label": "Details", "format": "multiline" }
      ],
      "visible_where": { "column": "archived", "values": ["0"] },
      "aggregates": [
        { "label": "Dishes signed up", "table": "guest_signups", "fk_column": "event_id", "op": "count" },
        { "label": "What guests are bringing", "table": "guest_signups", "fk_column": "event_id", "op": "list", "value_column": "dish" }
      ],
      "submit": {
        "table": "guest_signups",
        "fk_column": "event_id",
        "fields": [
          { "column": "guest_name", "label": "Your name", "type": "text", "required": true, "max_length": 80 },
          { "column": "dish", "label": "What will you bring?", "type": "text", "required": true, "max_length": 120 },
          { "column": "category", "label": "Category", "type": "select", "required": false, "values": ["Main", "Side", "Dessert", "Drink", "Other"] }
        ],
        "max_submissions": 200,
        "event": "potluck.signup_submitted"
      }
    }
  },
  "row_policies": {
    "events": {
      "kind": "adult_writable"
    },
    "slots": {
      "kind": "adult_writable"
    },
    "claims": {
      "kind": "endpoint_only",
      "read": "everyone"
    },
    "guest_signups": {
      "kind": "endpoint_only",
      "read": "everyone",
      "max_rows": 200
    }
  },
  "slot_claims": {
    "slot_table": "slots",
    "slot_id_column": "id",
    "capacity_column": "capacity",
    "claims_table": "claims",
    "claim_id_column": "id",
    "slot_fk_column": "slot_id",
    "member_column": "member_id",
    "created_at_column": "claimed_at",
    "one_claim_per_member": true,
    "allow_release": true,
    "allowed_columns": ["note"],
    "max_text_lengths": { "note": 200 }
  },
  "publishes": ["potluck.event_created", "potluck.slot_claimed", "potluck.slot_released", "potluck.signup_submitted"],
  "nav": { "label": "Potluck" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🍽️",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["upcoming_potlucks", "claim_summary"]
  }
}
