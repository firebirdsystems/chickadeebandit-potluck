{
  "id": "potluck",
  "name": "Potluck",
  "version": "1.0.0",
  "description": "Create gatherings with dish slots and let members claim, swap, and release dishes without overbooking a category.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": ["food", "events", "potluck", "slot-claims"],
  "data_access": {
    "reads": ["family.members"],
    "writes": ["family.members"]
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_plaintext_columns": ["capacity", "note"],
  "row_policies": {
    "events": {
      "kind": "adult_writable"
    },
    "slots": {
      "kind": "adult_writable"
    },
    "claims": {
      "kind": "endpoint_only",
      "read": "everyone"
    }
  },
  "slot_claims": {
    "slot_table": "slots",
    "slot_id_column": "id",
    "capacity_column": "capacity",
    "claims_table": "claims",
    "claim_id_column": "id",
    "slot_fk_column": "slot_id",
    "member_column": "member_id",
    "created_at_column": "claimed_at",
    "one_claim_per_member": true,
    "allow_release": true,
    "allowed_columns": ["note"],
    "max_text_lengths": { "note": 200 }
  },
  "publishes": ["potluck.event_created", "potluck.slot_claimed", "potluck.slot_released"],
  "nav": { "label": "Potluck" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🍽️",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["upcoming_potlucks", "claim_summary"]
  }
}
